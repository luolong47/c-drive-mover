{
  "name": "c-drive-mover",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "lint": "biome check --write .",
    "prebuild": "(sudo taskkill /F /IM c-drive-mover.exe /T 2>nul || type nul) & pnpm lint",
    "build": "set NEXT_PRIVATE_LOCAL_SKIP_WASM_HASH=1&& tauri build && node -e \"const fs=require('fs'); if(!fs.existsSync('dist/release'))fs.mkdirSync('dist/release', {recursive:true}); fs.copyFileSync('src-tauri/target/release/c-drive-mover.exe', 'dist/release/c-drive-mover.exe')\""
  },
  "dependencies": {
    "@google/genai": "^1.17.0",
    "@hookform/resolvers": "^5.2.1",
    "@tauri-apps/plugin-sql": "~2.3.2",
    "autoprefixer": "^10.4.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.553.0",
    "motion": "^12.23.24",
    "next": "^15.4.9",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@tailwindcss/postcss": "4.1.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "firebase-tools": "^15.0.0",
    "tailwindcss": "4.1.11",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3"
  }
}

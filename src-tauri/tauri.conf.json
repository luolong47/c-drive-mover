{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "c-drive-mover",
  "version": "0.1.0",
  "identifier": "com.cdrive-mover.applet",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm exec next dev",
    "beforeBuildCommand": "pnpm exec next build"
  },
  "app": {
    "windows": [
      {
        "title": "C Drive Mover",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
